NODE_ENV=development
APP_NAME=GymChallenge
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://gymchallenge:gymchallenge@postgres:5432/gymchallenge?schema=public
REDIS_URL=redis://redis:6379
AUTH_SECRET=change-this-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=gymchallenge-private
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=change-me
S3_FORCE_PATH_STYLE=true
EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE_NAME=
EVOLUTION_WEBHOOK_SECRET=
EVOLUTION_API_ENABLED=false
EVOLUTION_FAKE_MODE=true
WHATSAPP_DEFAULT_COUNTRY_CODE=57
DEFAULT_TIMEZONE=America/Bogota
DEFAULT_CURRENCY=COP
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-this-secure-password
SEED_USER1_PASSWORD=change-this-test-user-password
SEED_USER2_PASSWORD=change-this-test-user-password
EXERCISE_MEDIA_LICENSED=0
EXERCISE_DATASET_PATH=/var/www/html/nova-gym/vendor/exercises-dataset
EXERCISE_OPTIMIZED_MEDIA_PATH=/var/www/html/nova-gym/storage/exercise-media
