{
  "name": "gymchallenge",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm --filter @gymchallenge/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @gymchallenge/database generate",
    "db:migrate": "pnpm --filter @gymchallenge/database migrate",
    "db:seed": "pnpm --filter @gymchallenge/database seed"
  },
  "devDependencies": { "typescript": "^5.8.3" }
}
