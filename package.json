{
  "name": "gymchallenge",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm --filter @gymchallenge/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "dotenv -e .env -- pnpm --filter @gymchallenge/database generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @gymchallenge/database migrate",
    "db:seed": "dotenv -e .env -- pnpm --filter @gymchallenge/database seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^20.19.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.30.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0"
  }
}
