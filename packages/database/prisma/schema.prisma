generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_PASSWORD_CHANGE
}

enum PlanStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
}

enum AttendanceStatus {
  IN_PROGRESS
  COMPLETED
  INVALIDATED
  CANCELED
}

enum AttendancePhotoType {
  START
  END
}

enum PointMovementType {
  ATTENDANCE_EARNED
  ATTENDANCE_REVOKED
  ADMIN_ADJUSTMENT
  CHALLENGE_BONUS
  CHALLENGE_BONUS_REVOKED
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
  CANCELED
}

enum ChallengeCategoryStatus {
  ACTIVE
  INACTIVE
}

enum ChallengeType {
  MOST_ATTENDANCES
  FIRST_TO_TARGET
  REACH_TARGET
  STREAK
  ACCUMULATED_AMOUNT
}

enum ChallengeStatus {
  PENDING
  REJECTED
  ACTIVE
  COMPLETED
  CANCELED
  EXPIRED
}

enum ChallengeResult {
  PENDING
  WIN
  LOSS
  DRAW
  COMPLETED
  FAILED
  CANCELED
}

enum ChallengeReviewVerdict {
  CONFIRMED
  REJECTED
}

enum ChallengeTemplateStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ChallengeTemplateDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ChallengeModality {
  SOLO
  HEAD_TO_HEAD
  GROUP
}

enum ChallengeEvidenceType {
  NONE
  CHECK_IN
  ONE_PHOTO
  TWO_PHOTOS
  TEXT
  CHECKLIST
  NUMERIC_VALUE
  PHOTO_AND_VALUE
}

enum ChallengeTemplateFieldPolicy {
  LOCKED
  EDITABLE
  EDITABLE_WITH_LIMITS
}

enum ChallengeCompletionStatus {
  DRAFT
  IN_PROGRESS
  SUBMITTED
  VALID
  INVALID
  CANCELED
}

enum ChallengeValidationMethod {
  AUTOMATIC
  ADMIN_REVIEW
  SELF_REPORTED
}

enum ChallengeCompletionEvidenceType {
  START_PHOTO
  END_PHOTO
  SINGLE_PHOTO
  ATTACHMENT
}

enum EvidenceProcessingStatus {
  PENDING
  READY
  FAILED
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  CHALLENGE_INVITE
  CHALLENGE_STARTED
  CHALLENGE_PROGRESS
  CHALLENGE_COMPLETED
  ATTENDANCE_COMPLETED
  EVIDENCE_REVIEWED
  CLUB_SESSION
  SYSTEM
}

enum SocialPostType {
  WORKOUT
  ACHIEVEMENT
  CHALLENGE
  STATUS
}

enum SocialAudience {
  PRIVATE
  FRIENDS
  CHALLENGE_TEAM
  CLUB
}

enum SocialReactionType {
  FIRE
  STRONG
  APPLAUSE
  INSPIRE
}

enum ClubType {
  GYM
  CITY
  DISCIPLINE
  COMMUNITY
}

enum ClubVisibility {
  PUBLIC
  REQUEST
  PRIVATE
}

enum ClubRole {
  OWNER
  ADMIN
  MEMBER
}

enum ClubMembershipStatus {
  PENDING
  INVITED
  ACTIVE
  REJECTED
  LEFT
}

enum ClubSessionStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum ClubSessionParticipantStatus {
  GOING
  WAITLIST
  CANCELED
}

enum RoutineDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum WorkoutSessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

model User {
  id                         String                      @id @default(uuid()) @db.Uuid
  email                      String                      @unique @db.VarChar(255)
  username                   String                      @unique @db.VarChar(40)
  passwordHash               String                      @map("password_hash") @db.VarChar(255)
  role                       UserRole                    @default(USER)
  status                     UserStatus                  @default(PENDING_PASSWORD_CHANGE)
  whatsappNumber             String?                     @unique @map("whatsapp_number") @db.VarChar(20)
  countryCode                String?                     @map("country_code") @db.VarChar(4)
  failedLoginAttempts        Int                         @default(0) @map("failed_login_attempts")
  lockedUntil                DateTime?                   @map("locked_until")
  lastLoginAt                DateTime?                   @map("last_login_at")
  passwordChangedAt          DateTime?                   @map("password_changed_at")
  createdAt                  DateTime                    @default(now()) @map("created_at")
  updatedAt                  DateTime                    @updatedAt @map("updated_at")
  deletedAt                  DateTime?                   @map("deleted_at")
  profile                    UserProfile?
  sessions                   Session[]
  passwordResetTokens        PasswordResetToken[]
  subscriptions              Subscription[]
  auditLogs                  AuditLog[]                  @relation("AuditActor")
  createdUsers               User[]                      @relation("UserCreator")
  createdBy                  User?                       @relation("UserCreator", fields: [createdById], references: [id])
  createdById                String?                     @map("created_by_id") @db.Uuid
  attendances                Attendance[]
  attendancePhotos           AttendancePhoto[]
  pointMovements             PointLedger[]               @relation("PointOwner")
  pointMovementsCreated      PointLedger[]               @relation("PointActor")
  friendshipRequestsSent     Friendship[]                @relation("FriendRequester")
  friendshipRequestsReceived Friendship[]                @relation("FriendAddressee")
  challengesCreated          Challenge[]                 @relation("ChallengeCreator")
  challengeParticipants      ChallengeParticipant[]
  challengeScoreEvents       ChallengeScoreEvent[]
  challengeReviewsGiven      ChallengeAttendanceReview[] @relation("ChallengeReviewAuthor")
  challengeEvidenceViews     ChallengeEvidenceView[]     @relation("ChallengeEvidenceViewer")
  notifications              Notification[]              @relation("NotificationRecipient")
  notificationsTriggered     Notification[]              @relation("NotificationActor")
  challengeTemplateVersions  ChallengeTemplateVersion[]  @relation("ChallengeTemplateVersionCreator")
  challengeCompletions       ChallengeCompletion[]
  challengeResults           ChallengeResultRecord[]
  personalChallengeTemplates UserChallengeTemplate[]
  challengeDrafts            ChallengeDraft[]
  challengeRestDays          ChallengeRestDay[]
  socialPosts                SocialPost[]
  socialReactions            SocialReaction[]
  socialComments             SocialComment[]
  clubsOwned                 Club[]                      @relation("ClubOwner")
  clubMemberships            ClubMembership[]
  clubSessionsCreated        ClubSession[]               @relation("ClubSessionCreator")
  clubSessionParticipations  ClubSessionParticipant[]
  routines                   Routine[]
  workoutSessions            WorkoutSession[]

  @@index([status])
  @@map("users")
}

model ExerciseCatalog {
  id                 String            @id @db.VarChar(20)
  name               String            @db.VarChar(180)
  nameEs             String?           @map("name_es") @db.VarChar(180)
  category           String            @db.VarChar(80)
  bodyPart           String            @map("body_part") @db.VarChar(80)
  equipment          String            @db.VarChar(100)
  target             String            @db.VarChar(100)
  muscleGroup        String?           @map("muscle_group") @db.VarChar(100)
  secondaryMuscles   String[]          @map("secondary_muscles")
  instructionsEs     String            @map("instructions_es") @db.Text
  instructionStepsEs String[]          @map("instruction_steps_es")
  imagePath          String?           @map("image_path") @db.VarChar(300)
  gifPath            String?           @map("gif_path") @db.VarChar(300)
  attribution        String?           @db.VarChar(300)
  source             String            @default("hasaneyldrm/exercises-dataset") @db.VarChar(100)
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  routineExercises   RoutineExercise[]

  @@index([category])
  @@index([bodyPart])
  @@index([equipment])
  @@index([target])
  @@map("exercise_catalog")
}

model Routine {
  id               String            @id @default(uuid()) @db.Uuid
  slug             String            @unique @db.VarChar(120)
  ownerId          String?           @map("owner_id") @db.Uuid
  name             String            @db.VarChar(140)
  description      String            @db.VarChar(600)
  goal             String            @db.VarChar(100)
  difficulty       RoutineDifficulty @default(BEGINNER)
  estimatedMinutes Int               @map("estimated_minutes")
  isFeatured       Boolean           @default(false) @map("is_featured")
  isPublic         Boolean           @default(false) @map("is_public")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  owner            User?             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  exercises        RoutineExercise[]
  workoutSessions  WorkoutSession[]

  @@index([ownerId, createdAt])
  @@index([isPublic, isFeatured])
  @@map("routines")
}

model RoutineExercise {
  id              String          @id @default(uuid()) @db.Uuid
  routineId       String          @map("routine_id") @db.Uuid
  exerciseId      String          @map("exercise_id") @db.VarChar(20)
  position        Int
  sets            Int             @default(3)
  reps            Int?
  durationSeconds Int?            @map("duration_seconds")
  restSeconds     Int             @default(60) @map("rest_seconds")
  notes           String?         @db.VarChar(300)
  routine         Routine         @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercise        ExerciseCatalog @relation(fields: [exerciseId], references: [id])
  setLogs         WorkoutSetLog[]

  @@unique([routineId, position])
  @@index([routineId])
  @@index([exerciseId])
  @@map("routine_exercises")
}

model WorkoutSession {
  id                   String               @id @default(uuid()) @db.Uuid
  userId               String               @map("user_id") @db.Uuid
  routineId            String               @map("routine_id") @db.Uuid
  status               WorkoutSessionStatus @default(ACTIVE)
  startedAt            DateTime             @default(now()) @map("started_at")
  segmentStartedAt     DateTime?            @default(now()) @map("segment_started_at")
  endedAt              DateTime?            @map("ended_at")
  accumulatedSeconds   Int                  @default(0) @map("accumulated_seconds")
  currentExerciseIndex Int                  @default(0) @map("current_exercise_index")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  routine              Routine              @relation(fields: [routineId], references: [id], onDelete: Restrict)
  setLogs              WorkoutSetLog[]

  @@index([userId, createdAt])
  @@index([routineId, createdAt])
  @@map("workout_sessions")
}

model WorkoutSetLog {
  id                String          @id @default(uuid()) @db.Uuid
  sessionId         String          @map("session_id") @db.Uuid
  routineExerciseId String          @map("routine_exercise_id") @db.Uuid
  setNumber         Int             @map("set_number")
  reps              Int?
  weightKg          Decimal?        @map("weight_kg") @db.Decimal(6, 2)
  durationSeconds   Int?            @map("duration_seconds")
  completedAt       DateTime        @default(now()) @map("completed_at")
  session           WorkoutSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  routineExercise   RoutineExercise @relation(fields: [routineExerciseId], references: [id], onDelete: Cascade)

  @@unique([sessionId, routineExerciseId, setNumber])
  @@index([sessionId, completedAt])
  @@map("workout_set_logs")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  actorId   String?          @map("actor_id") @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(140)
  body      String           @db.VarChar(500)
  href      String?          @db.VarChar(500)
  data      Json?
  readAt    DateTime?        @map("read_at")
  dedupeKey String?          @unique @map("dedupe_key") @db.VarChar(200)
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor     User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model SocialPost {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  attendanceId String?          @unique @map("attendance_id") @db.Uuid
  challengeId  String?          @map("challenge_id") @db.Uuid
  clubId       String?          @map("club_id") @db.Uuid
  type         SocialPostType   @default(WORKOUT)
  audience     SocialAudience   @default(FRIENDS)
  content      String?          @db.VarChar(800)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendance   Attendance?      @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  challenge    Challenge?       @relation(fields: [challengeId], references: [id], onDelete: SetNull)
  club         Club?            @relation(fields: [clubId], references: [id], onDelete: SetNull)
  reactions    SocialReaction[]
  comments     SocialComment[]

  @@index([userId, createdAt])
  @@index([audience, createdAt])
  @@index([challengeId, createdAt])
  @@index([clubId, createdAt])
  @@map("social_posts")
}

model Club {
  id          String           @id @default(uuid()) @db.Uuid
  ownerId     String           @map("owner_id") @db.Uuid
  name        String           @db.VarChar(120)
  slug        String           @unique @db.VarChar(140)
  description String           @db.VarChar(600)
  type        ClubType
  visibility  ClubVisibility   @default(PUBLIC)
  city        String?          @db.VarChar(120)
  country     String           @default("Colombia") @db.VarChar(100)
  department  String?          @db.VarChar(120)
  discipline  String?          @db.VarChar(120)
  disciplines String[]         @default([])
  latitude    Decimal?         @db.Decimal(10, 7)
  longitude   Decimal?         @db.Decimal(10, 7)
  avatarKey   String?          @map("avatar_key") @db.VarChar(500)
  accentColor String           @default("lime") @map("accent_color") @db.VarChar(20)
  memberLimit Int              @default(500) @map("member_limit")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  owner       User             @relation("ClubOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships ClubMembership[]
  socialPosts SocialPost[]
  sessions    ClubSession[]

  @@index([type, visibility, createdAt])
  @@index([city])
  @@index([discipline])
  @@index([country, department, city])
  @@map("clubs")
}

model ClubSession {
  id              String                   @id @default(uuid()) @db.Uuid
  clubId          String                   @map("club_id") @db.Uuid
  creatorId       String                   @map("creator_id") @db.Uuid
  title           String                   @db.VarChar(140)
  description     String?                  @db.VarChar(600)
  startsAt        DateTime                 @map("starts_at")
  durationMinutes Int                      @default(60) @map("duration_minutes")
  placeName       String                   @map("place_name") @db.VarChar(160)
  address         String?                  @db.VarChar(240)
  latitude        Decimal?                 @db.Decimal(10, 7)
  longitude       Decimal?                 @db.Decimal(10, 7)
  capacity        Int                      @default(10)
  status          ClubSessionStatus        @default(SCHEDULED)
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  club            Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  creator         User                     @relation("ClubSessionCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  participants    ClubSessionParticipant[]

  @@index([clubId, status, startsAt])
  @@index([creatorId, startsAt])
  @@map("club_sessions")
}

model ClubSessionParticipant {
  id        String                       @id @default(uuid()) @db.Uuid
  sessionId String                       @map("session_id") @db.Uuid
  userId    String                       @map("user_id") @db.Uuid
  status    ClubSessionParticipantStatus @default(GOING)
  joinedAt  DateTime?                    @map("joined_at")
  createdAt DateTime                     @default(now()) @map("created_at")
  updatedAt DateTime                     @updatedAt @map("updated_at")
  session   ClubSession                  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User                         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([userId, status])
  @@index([sessionId, status])
  @@map("club_session_participants")
}

model ClubMembership {
  id        String               @id @default(uuid()) @db.Uuid
  clubId    String               @map("club_id") @db.Uuid
  userId    String               @map("user_id") @db.Uuid
  role      ClubRole             @default(MEMBER)
  status    ClubMembershipStatus @default(PENDING)
  joinedAt  DateTime?            @map("joined_at")
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")
  club      Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([userId, status])
  @@index([clubId, status, role])
  @@map("club_memberships")
}

model SocialReaction {
  id        String             @id @default(uuid()) @db.Uuid
  postId    String             @map("post_id") @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  type      SocialReactionType
  createdAt DateTime           @default(now()) @map("created_at")
  post      SocialPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId, type])
  @@map("social_reactions")
}

model SocialComment {
  id        String     @id @default(uuid()) @db.Uuid
  postId    String     @map("post_id") @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  content   String     @db.VarChar(500)
  createdAt DateTime   @default(now()) @map("created_at")
  deletedAt DateTime?  @map("deleted_at")
  post      SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId, createdAt])
  @@map("social_comments")
}

model Attendance {
  id                     String                      @id @default(uuid()) @db.Uuid
  userId                 String                      @map("user_id") @db.Uuid
  localDate              DateTime                    @map("local_date") @db.Date
  timezone               String                      @db.VarChar(80)
  status                 AttendanceStatus            @default(IN_PROGRESS)
  startedAt              DateTime                    @default(now()) @map("started_at")
  startLatitude          Decimal?                    @map("start_latitude") @db.Decimal(9, 6)
  startLongitude         Decimal?                    @map("start_longitude") @db.Decimal(9, 6)
  startAccuracyMeters    Decimal?                    @map("start_accuracy_meters") @db.Decimal(8, 2)
  finishedAt             DateTime?                   @map("finished_at")
  endLatitude            Decimal?                    @map("end_latitude") @db.Decimal(9, 6)
  endLongitude           Decimal?                    @map("end_longitude") @db.Decimal(9, 6)
  endAccuracyMeters      Decimal?                    @map("end_accuracy_meters") @db.Decimal(8, 2)
  durationMinutes        Int?                        @map("duration_minutes")
  notes                  String?                     @db.VarChar(500)
  invalidatedAt          DateTime?                   @map("invalidated_at")
  invalidatedById        String?                     @map("invalidated_by_id") @db.Uuid
  invalidationReason     String?                     @map("invalidation_reason") @db.VarChar(500)
  createdAt              DateTime                    @default(now()) @map("created_at")
  updatedAt              DateTime                    @updatedAt @map("updated_at")
  user                   User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos                 AttendancePhoto[]
  pointMovements         PointLedger[]
  challengeScoreEvents   ChallengeScoreEvent[]
  challengeReviews       ChallengeAttendanceReview[]
  challengeEvidenceViews ChallengeEvidenceView[]
  socialPost             SocialPost?

  @@unique([userId, localDate])
  @@index([userId, status])
  @@index([localDate])
  @@map("attendances")
}

model Friendship {
  id          String           @id @default(uuid()) @db.Uuid
  requesterId String           @map("requester_id") @db.Uuid
  addresseeId String           @map("addressee_id") @db.Uuid
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  requester   User             @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User             @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@map("friendships")
}

model ChallengeCategory {
  id                  String                  @id @default(uuid()) @db.Uuid
  name                String                  @db.VarChar(120)
  slug                String                  @unique @db.VarChar(120)
  description         String                  @db.VarChar(500)
  type                ChallengeType
  status              ChallengeCategoryStatus @default(ACTIVE)
  durationDays        Int                     @map("duration_days")
  targetAttendances   Int                     @map("target_attendances")
  pointsPerAttendance Int                     @default(1) @map("points_per_attendance")
  completionBonus     Int                     @default(0) @map("completion_bonus")
  winnerBonus         Int                     @default(0) @map("winner_bonus")
  icon                String                  @default("flame") @db.VarChar(50)
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")
  challenges          Challenge[]
  templates           ChallengeTemplate[]
  personalTemplates   UserChallengeTemplate[]

  @@map("challenge_categories")
}

model ChallengeTemplate {
  id               String                      @id @default(uuid()) @db.Uuid
  categoryId       String                      @map("category_id") @db.Uuid
  minimumPlanId    String?                     @map("minimum_plan_id") @db.Uuid
  name             String                      @db.VarChar(160)
  slug             String                      @unique @db.VarChar(160)
  shortDescription String                      @map("short_description") @db.VarChar(500)
  coverImageKey    String?                     @map("cover_image_key") @db.VarChar(500)
  icon             String                      @default("flame") @db.VarChar(50)
  tags             String[]                    @default([])
  difficulty       ChallengeTemplateDifficulty @default(BEGINNER)
  status           ChallengeTemplateStatus     @default(DRAFT)
  sortOrder        Int                         @default(0) @map("sort_order")
  featured         Boolean                     @default(false)
  official         Boolean                     @default(true)
  usageCount       Int                         @default(0) @map("usage_count")
  createdAt        DateTime                    @default(now()) @map("created_at")
  updatedAt        DateTime                    @updatedAt @map("updated_at")
  category         ChallengeCategory           @relation(fields: [categoryId], references: [id])
  minimumPlan      Plan?                       @relation(fields: [minimumPlanId], references: [id], onDelete: SetNull)
  versions         ChallengeTemplateVersion[]
  challenges       Challenge[]
  ruleSnapshots    ChallengeRuleSnapshot[]

  @@index([status, featured, sortOrder])
  @@index([categoryId, status])
  @@map("challenge_templates")
}

model ChallengeTemplateVersion {
  id                  String                   @id @default(uuid()) @db.Uuid
  templateId          String                   @map("template_id") @db.Uuid
  createdById         String?                  @map("created_by_id") @db.Uuid
  version             Int
  fullDescription     String                   @map("full_description") @db.Text
  challengeType       ChallengeType            @map("challenge_type")
  allowedModalities   ChallengeModality[]      @map("allowed_modalities")
  defaultDurationDays Int                      @map("default_duration_days")
  minimumDurationDays Int                      @map("minimum_duration_days")
  maximumDurationDays Int                      @map("maximum_duration_days")
  validWeekdays       Int[]                    @default([1, 2, 3, 4, 5, 6, 7]) @map("valid_weekdays")
  defaultTargetValue  Int                      @map("default_target_value")
  targetUnit          String                   @map("target_unit") @db.VarChar(50)
  evidenceType        ChallengeEvidenceType    @map("evidence_type")
  requiredPhotoCount  Int                      @default(0) @map("required_photo_count")
  pointsPerCompletion Int                      @default(1) @map("points_per_completion")
  completionBonus     Int                      @default(0) @map("completion_bonus")
  winnerBonus         Int                      @default(0) @map("winner_bonus")
  maxDailyCompletions Int                      @default(1) @map("max_daily_completions")
  scoringRules        Json                     @map("scoring_rules")
  winningRule         Json                     @map("winning_rule")
  tieRule             Json                     @map("tie_rule")
  instructions        String                   @db.Text
