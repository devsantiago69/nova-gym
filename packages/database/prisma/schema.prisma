model Challenge {
  id                  String                      @id @default(uuid()) @db.Uuid
  categoryId          String                      @map("category_id") @db.Uuid
  templateId          String?                     @map("template_id") @db.Uuid
  templateVersionId   String?                     @map("template_version_id") @db.Uuid
  creatorId           String                      @map("creator_id") @db.Uuid
  name                String                      @default("") @db.VarChar(160)
  description         String                      @default("") @db.VarChar(1000)
  modality            ChallengeModality           @default(HEAD_TO_HEAD)
  durationDays        Int                         @default(1) @map("duration_days")
  restDaysAllowed     Int                         @default(2) @map("rest_days_allowed")
  timezone            String                      @default("America/Bogota") @db.VarChar(80)
  targetValue         Int                         @default(1) @map("target_value")
  targetUnit          String                      @default("attendances") @map("target_unit") @db.VarChar(50)
  evidenceType        ChallengeEvidenceType       @default(TWO_PHOTOS) @map("evidence_type")
  pointsPerCompletion Int                         @default(1) @map("points_per_completion")
  maxDailyCompletions Int                         @default(1) @map("max_daily_completions")
  status              ChallengeStatus             @default(PENDING)
  message             String?                     @db.VarChar(300)
  startsAt            DateTime                    @map("starts_at")
  endsAt              DateTime                    @map("ends_at")
  acceptedAt          DateTime?                   @map("accepted_at")
  createdAt           DateTime                    @default(now()) @map("created_at")
  updatedAt           DateTime                    @updatedAt @map("updated_at")
  category            ChallengeCategory           @relation(fields: [categoryId], references: [id])
  template            ChallengeTemplate?          @relation(fields: [templateId], references: [id], onDelete: Restrict)
  templateVersion     ChallengeTemplateVersion?   @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  creator             User                        @relation("ChallengeCreator", fields: [creatorId], references: [id])
  participants        ChallengeParticipant[]
  scoreEvents         ChallengeScoreEvent[]
  attendanceReviews   ChallengeAttendanceReview[]
  evidenceViews       ChallengeEvidenceView[]
  ruleSnapshot        ChallengeRuleSnapshot?
  completions         ChallengeCompletion[]
  checklistItems      ChallengeChecklistItem[]
  personalTemplates   UserChallengeTemplate[]
  results             ChallengeResultRecord[]
  socialPosts         SocialPost[]
  restDays            ChallengeRestDay[]

  @@index([status, startsAt, endsAt])
  @@index([templateId])
  @@index([templateVersionId])
  @@map("challenges")
}

